// Commands to know:
// `npx prisma generate` - update TypeScript definitions based on this schema
// `npx prisma db push` - push the schema changes to the database
// `npx prisma studio` - open the Studio, which allows you to edit the schema.
// `npx prisma migrate reset` - reset the migrations to the last version. This will reset the DB and run the seed script
// `npx prisma migrate dev --name <descriptive-name>` - generate a migration file for any changes you make to the schema (this will be committed).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  username     String    @unique
  role         Role      @default(BASIC)
  email        String    @unique
  fullName     String
  passwordHash String
  projects     Project[]
  posts        Post[]
}

model Post {
  id          String   @id @default(cuid())
  title       String
  content     Json?
  type        PostType @default(BASIC_NOTES)
  isPublished Boolean  @default(false)
  isFavorite  Boolean  @default(false)
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  User        User?    @relation(fields: [userId], references: [id])
  userId      String?

  @@index([userId])
}

model Project {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  description String
  type        String
  heroId      String
  userId      String
  liveLink    String
  content     String?
  owner       User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum Role {
  OWNER
  CLIENT
  BASIC
}

enum PostType {
  MONTHLY_PLANNING
  BASIC_NOTES
  DEBT
  INVESTMENT
  SAVING
  GOLD
  STOCK
}
