{
  "name": "ommiputera.com",
  "version": "1.0.0",
  "description": "A remix version of ommiputera.com",
  "sideEffects": false,
  "scripts": {
    "build": "prisma generate && remix build",
    "clean": "rm -rf ./node_modules/ .cache/",
    "dev": "conc \"npm:remix-dev\" \"npm:pscale-dev-server\"",
    "format": "prettier --write \"**/*.+(js|jsx|json|yml|yaml|css|less|scss|ts|tsx|md|gql|graphql|mdx|vue)\"",
    "postinstall": "prisma generate",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/.eslintcache --ext js,jsx,ts,tsx .",
    "prepare": "husky install || true",
    "pscale-dev-server": "pscale connect ommiputera initial-setup --port 3306",
    "remix-dev": "remix dev",
    "typecheck": "tsc"
  },
  "eslintIgnore": [
    "node_modules",
    "coverage",
    "server-build",
    "build",
    "other",
    "public/build",
    "*.ignored/",
    "*.ignored.*",
    "/content/blog/fix-the-not-wrapped-in-act-warning/components.jsx",
    "/test-results/",
    "/playwright-report/",
    "/playwright/.cache/"
  ],
  "dependencies": {
    "@blocknote/core": "^0.8.1",
    "@blocknote/react": "^0.8.1",
    "@prisma/client": "^4.14.0",
    "@radix-ui/react-navigation-menu": "^1.1.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.6",
    "@reach/dialog": "^0.18.0",
    "@reach/menu-button": "^0.18.0",
    "@reach/tabs": "^0.18.0",
    "@remix-run/node": "^1.15.0",
    "@remix-run/react": "^1.15.0",
    "@remix-run/vercel": "^1.15.0",
    "@tailwindcss/typography": "^0.5.9",
    "@tanstack/react-table": "^8.9.2",
    "@types/lodash": "^4.14.195",
    "@vercel/analytics": "^1.0.1",
    "@vercel/node": "^2.6.2",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.6.1",
    "cloudinary-build-url": "^0.2.4",
    "clsx": "^1.2.1",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.12.16",
    "isbot": "^3.6.5",
    "lodash": "^4.17.21",
    "lucide-react": "^0.252.0",
    "postcss-import": "^15.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "spin-delay": "^1.2.0",
    "tailwind-merge": "^1.13.2",
    "tailwindcss-animate": "^1.0.6"
  },
  "devDependencies": {
    "@cld-apis/types": "^0.1.6",
    "@remix-run/dev": "^1.15.0",
    "@remix-run/eslint-config": "^1.15.0",
    "@remix-run/serve": "^1.15.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.8",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "eslint": "^8.27.0",
    "husky": "^8.0.3",
    "postcss": "^8.4.23",
    "postcss-cli": "^10.1.0",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "prisma": "^4.14.1",
    "tailwindcss": "^3.3.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^4.8.4"
  },
  "engines": {
    "node": "18",
    "npm": "8"
  },
  "prisma": {
    "seed": "ts-node --require tsconfig-paths/register prisma/seed.ts"
  }
}
